# Konfigurasi Database PostgreSQL
PGHOST=localhost
PGUSER=postgres
PGPASSWORD=password_postgres_anda
PGDATABASE=qlop
PGPORT=5432
DATABASE_URL=postgres://postgres:password_postgres_anda@localhost:5432/qlop

# Konfigurasi Server Express
HOST=localhost
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Autentikasi JWT (buat kunci rahasia yang kuat, minimal 32 karakter)
ACCESS_TOKEN_KEY=kunci_jwt_akses_rahasia_super_anda_minimal_32_karakter
REFRESH_TOKEN_KEY=kunci_jwt_refresh_rahasia_super_anda_minimal_32_karakter
ACCESS_TOKEN_AGE=1800

# Google OAuth 2.0 (Opsional, untuk fitur masuk dengan akun Google)
GOOGLE_CLIENT_ID=client_id_google_oauth_anda.apps.googleusercontent.com

# Konfigurasi Penyimpanan Cloudinary (Diperlukan untuk unggah PDF CV)
CLOUDINARY_CLOUD_NAME=nama_cloud_cloudinary_anda
CLOUDINARY_API_KEY=api_key_cloudinary_anda
CLOUDINARY_API_SECRET=api_secret_cloudinary_anda

# Endpoint API Layanan AI Engine (default ke localhost:8000)
AI_API_URL=http://localhost:8000
