# QLOP AI Engine environment configuration
# Copy this file to .env and fill in your values

# Groq API key (required for Career Pivot Radar)
# Get yours FREE (no credit card required) at: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Groq model — choose based on speed vs quality trade-off:
#   llama-3.1-8b-instant     → fast; ~6k TPM per request (input + max_tokens combined)
#   meta-llama/llama-4-scout-17b-16e-instruct → ~30k TPM, better quality (recommended for demo)
#   llama-3.3-70b-versatile  → best quality, tight TPM limits
GROQ_MODEL=llama-3.1-8b-instant

# Max output tokens per Career Pivot call. Groq rejects if prompt_tokens + GROQ_MAX_TOKENS > model TPM.
# Keep at 2048 for llama-3.1-8b-instant; can raise to 3500+ on Scout 17B.
# GROQ_MAX_TOKENS=2048

# SBERT RAG: number of alternative roles injected into the LLM prompt (default 4)
# CAREER_PIVOT_TOP_K=4

# NER model base — downloaded automatically from HuggingFace on first startup
NER_BASE_MODEL=microsoft/deberta-v3-base
NER_CONFIDENCE_THRESHOLD=0.5

# HuggingFace model cache directory
# All HuggingFace downloads (DeBERTa ~750 MB + SBERT ~90 MB) are stored here.
# The default (model_assets/hf_cache/) keeps the cache inside the project so it
# survives server restarts without re-downloading.
# Override this on shared servers to a persistent volume path, e.g.:
#   HF_CACHE_DIR=/data/hf_cache
# HF_CACHE_DIR=model_assets/hf_cache

# SBERT model — change to a larger model if readiness scoring needs improvement
# Options: all-MiniLM-L6-v2 (fast, 90 MB) | all-mpnet-base-v2 (accurate, 420 MB)
# SBERT_MODEL_NAME=all-MiniLM-L6-v2
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Security & Documentation (New) ---
# API Key required by Express Backend to authenticate requests to AI Engine.
# Ensure this matches the Express backend configuration.
INTERNAL_API_KEY=kunci_rahasia_api_engine_anda

# Set to false to disable Swagger UI (/docs) and OpenAPI specs in production
ENABLE_DOCS=true

