# QLOP AI Engine environment configuration

# Google AI Studio API key (required for Career Pivot Radar)
# Get yours free at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza-your-google-ai-studio-key-here

# Gemini model (default: gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash

# NER model base (default: microsoft/deberta-v3-base)
NER_BASE_MODEL=microsoft/deberta-v3-base
NER_CONFIDENCE_THRESHOLD=0.5
